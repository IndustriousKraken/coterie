# Coterie environment configuration
#
# Copy this file to `.env` (in the working directory of the binary) and
# fill in your values. Coterie loads `.env` automatically at startup.
#
# Format: COTERIE__<section>__<field>=<value>
# Double underscores (`__`) separate config levels — the `config` crate
# uses single underscore for words within a field name.
#
# All UNCOMMENTED settings below are REQUIRED. The server will refuse
# to start with a clear error if any are missing or unparseable.
# Optional settings are commented out with notes on what they unlock.
#
# ---------------------------------------------------------------------
# SERVER
# ---------------------------------------------------------------------

# Address Coterie binds to. Behind a reverse proxy, leave at 127.0.0.1
# so only the proxy can reach it. To listen on all interfaces (e.g. for
# direct exposure or container networking), use 0.0.0.0.
# REQUIRED. If missing: server fails to start with a config error.
COTERIE__SERVER__HOST=127.0.0.1

# TCP port. 8080 is the convention; pick anything else if it conflicts
# with another service on the host.
# REQUIRED.
COTERIE__SERVER__PORT=8080

# Public-facing URL of this Coterie instance. Used for:
#   - Email links (verification, password reset, dues reminders)
#   - Stripe Checkout success/cancel redirects
#   - Inferring the Secure flag on session cookies (https → on)
#   - Inferring trust of X-Forwarded-For headers (https → trusted)
# In production this MUST be your real https URL — wrong values silently
# break email links and Stripe redirects.
# REQUIRED.
COTERIE__SERVER__BASE_URL=http://localhost:8080

# Comma-separated list of origins allowed to call /public/* and /api/*
# from a browser (CORS). Set this to your public website's origin so
# the signup form, public donate form, etc. can POST to Coterie.
# Leave commented to restrict to same-origin only (no browser CORS).
# Server-to-server callers ignore CORS — this only affects browsers.
# OPTIONAL.
# COTERIE__SERVER__CORS_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Trust X-Forwarded-For / X-Real-Ip for client-IP detection (used by
# rate limiters and audit logs).
# Default: true when BASE_URL is https://, false otherwise — i.e.
# trusted when behind a TLS-terminating proxy, untrusted in plain HTTP
# dev. Override to false if this server faces untrusted clients
# directly without a proxy (otherwise IPs can be spoofed).
# OPTIONAL.
# COTERIE__SERVER__TRUST_FORWARDED_FOR=true

# Force the Secure flag on session cookies. Default: inferred from
# BASE_URL (https → true). Override to true if your reverse proxy
# terminates TLS but talks to Coterie over plain HTTP — Coterie can't
# detect that on its own and will issue insecure cookies otherwise.
# OPTIONAL.
# COTERIE__SERVER__SECURE_COOKIES=true

# Base directory for persistent data (database file, uploaded images).
# Auto-detected in this order:
#   1. /var/lib/coterie if it exists (standard Linux service location)
#   2. /data if running in a container (presence of /.dockerenv or CONTAINER env)
#   3. ./data otherwise (local development)
# Override to pin a specific path. The directory must exist and be
# writable by the user the binary runs as.
# OPTIONAL.
# COTERIE__SERVER__DATA_DIR=/var/lib/coterie

# Override the uploads directory specifically. Default: {data_dir}/uploads.
# Useful if you want uploads on a separate volume from the database.
# OPTIONAL.
# COTERIE__SERVER__UPLOADS_DIR=/var/lib/coterie/uploads

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------

# SQLite connection string. Two accepted forms:
#   sqlite://coterie.db          — bare filename, resolved against DATA_DIR
#   sqlite:///absolute/path.db   — absolute path (note three slashes)
# WAL mode is enabled automatically. The file is created if missing.
# REQUIRED.
COTERIE__DATABASE__URL=sqlite://coterie.db

# Maximum concurrent SQLite connections in the pool. SQLite serializes
# writes regardless of pool size, but readers can run concurrently in
# WAL mode. 5–10 is plenty for a single-instance deployment.
# REQUIRED.
COTERIE__DATABASE__MAX_CONNECTIONS=10

# ---------------------------------------------------------------------
# AUTHENTICATION
# ---------------------------------------------------------------------

# Master application secret. Used to derive keys for:
#   - CSRF token signing (rotating invalidates outstanding tokens)
#   - Encryption of sensitive settings stored in the DB (e.g. SMTP password)
# NOT used to sign session cookies or hash passwords — rotating it does
# NOT log everyone out and does NOT invalidate passwords.
# Generate with: `openssl rand -hex 32`
# Treat as production-secret-grade. See deploy/OPS.md for rotation procedure.
# REQUIRED. If missing: server refuses to start.
COTERIE__AUTH__SESSION_SECRET=replace-with-a-long-random-string

# How long a login session stays valid before the user must log in again.
# 24 (one day) is a reasonable default for a member-management portal;
# increase for less-sensitive deployments, decrease for higher-stakes ones.
# REQUIRED.
COTERIE__AUTH__SESSION_DURATION_HOURS=24

# Issuer name shown in TOTP authenticator apps when 2FA enrolls. This
# is what users see in their Google Authenticator / 1Password TOTP list.
# REQUIRED (TOTP not yet implemented but the field is parsed at startup).
COTERIE__AUTH__TOTP_ISSUER=Coterie

# ---------------------------------------------------------------------
# EMAIL (configured at runtime, not via env)
# ---------------------------------------------------------------------
#
# Email config (SMTP host/port/credentials/from-address) is stored in
# the database, not in this file. Configure it from the admin portal
# at /portal/admin/settings/email after first boot.
#
# Until configured, Coterie runs in "log mode": emails are written to
# the tracing log instead of being delivered. Verification links,
# password resets, dues reminders, etc. all show up in `journalctl -u
# coterie`. This is fine for local dev; flip to SMTP mode before any
# real members sign up.

# ---------------------------------------------------------------------
# STRIPE (optional)
# ---------------------------------------------------------------------
#
# Without Stripe, Coterie still works — admins record payments manually
# and members can't self-serve. Enable to unlock saved cards, auto-renew,
# and the Checkout flow.

COTERIE__STRIPE__ENABLED=false

# Test keys start sk_test_ / pk_test_ / whsec_; live keys start sk_live_
# / pk_live_ / whsec_. Get them from https://dashboard.stripe.com/apikeys
# and the Webhooks section. The webhook secret comes from the specific
# endpoint you register pointing to /api/payments/webhook/stripe.
# REQUIRED when ENABLED=true.
# COTERIE__STRIPE__PUBLISHABLE_KEY=pk_test_...
# COTERIE__STRIPE__SECRET_KEY=sk_test_...
# COTERIE__STRIPE__WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------
# DISCORD (optional)
# ---------------------------------------------------------------------
#
# Members get a configured "Member" role on activation, lose it on
# expiration. Optional "Expired" role is granted on expiration so admins
# can see who lapsed. Daily reconcile catches drift from any events
# that didn't deliver during a Discord outage.
#
# To enable: create a bot at https://discord.com/developers/applications,
# invite it to your guild with the "Manage Roles" permission, and copy
# the bot token + IDs.

# COTERIE__INTEGRATIONS__DISCORD__ENABLED=false
# COTERIE__INTEGRATIONS__DISCORD__BOT_TOKEN=...
# COTERIE__INTEGRATIONS__DISCORD__GUILD_ID=...
# COTERIE__INTEGRATIONS__DISCORD__MEMBER_ROLE_ID=...
# COTERIE__INTEGRATIONS__DISCORD__EXPIRED_ROLE_ID=...

# ---------------------------------------------------------------------
# UNIFI ACCESS (optional, partial)
# ---------------------------------------------------------------------
#
# API client only — no provisioning logic yet. Setting these does
# nothing until the access provisioning flow ships. Safe to leave
# unset.

# COTERIE__INTEGRATIONS__UNIFI__ENABLED=false
# COTERIE__INTEGRATIONS__UNIFI__CONTROLLER_URL=https://unifi.example.com:8443
# COTERIE__INTEGRATIONS__UNIFI__USERNAME=...
# COTERIE__INTEGRATIONS__UNIFI__PASSWORD=...
# COTERIE__INTEGRATIONS__UNIFI__SITE_ID=default
