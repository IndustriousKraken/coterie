# Coterie Environment Configuration
# Copy to .env and fill in your values.
# All uncommented fields are required — the server will refuse to start without them.
# Note: Double underscores (__) separate config levels.

# Server Configuration
COTERIE__SERVER__HOST=127.0.0.1
COTERIE__SERVER__PORT=8080
COTERIE__SERVER__BASE_URL=http://localhost:8080

# CORS: Comma-separated origins allowed to call the API (for your public website).
# Leave commented out to restrict to same-origin only.
# COTERIE__SERVER__CORS_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Database Configuration
COTERIE__DATABASE__URL=sqlite://coterie.db
COTERIE__DATABASE__MAX_CONNECTIONS=10

# Authentication
COTERIE__AUTH__SESSION_SECRET=replace-with-a-long-random-string
COTERIE__AUTH__SESSION_DURATION_HOURS=24
COTERIE__AUTH__TOTP_ISSUER=Coterie

# Stripe Integration (optional — leave ENABLED=false to disable)
COTERIE__STRIPE__ENABLED=false
# COTERIE__STRIPE__PUBLISHABLE_KEY=pk_test_...
# COTERIE__STRIPE__SECRET_KEY=sk_test_...
# COTERIE__STRIPE__WEBHOOK_SECRET=whsec_...

# Discord Integration (optional)
# COTERIE__INTEGRATIONS__DISCORD__ENABLED=false
# COTERIE__INTEGRATIONS__DISCORD__BOT_TOKEN=...
# COTERIE__INTEGRATIONS__DISCORD__GUILD_ID=...
# COTERIE__INTEGRATIONS__DISCORD__MEMBER_ROLE_ID=...
# COTERIE__INTEGRATIONS__DISCORD__EXPIRED_ROLE_ID=...

# Unifi Integration (optional)
# COTERIE__INTEGRATIONS__UNIFI__ENABLED=false
# COTERIE__INTEGRATIONS__UNIFI__CONTROLLER_URL=https://unifi.example.com:8443
# COTERIE__INTEGRATIONS__UNIFI__USERNAME=...
# COTERIE__INTEGRATIONS__UNIFI__PASSWORD=...
# COTERIE__INTEGRATIONS__UNIFI__SITE_ID=default
